@using Microsoft.AspNet.Identity
@{
    ViewBag.Title = "_AdminMenu";
}

<h2>_AdminMenu</h2>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/Content/adminstyle.css">
</head>
@RenderSection("Scripts", required: false)
<body>

    <div class="d-flex">

        <!-- Sidebar -->
        <nav class="sidebar bg-dark text-light p-3" style="width: 250px; height: 100vh;">
            <div class="text-center mb-4">
                <h4>Admin Panel</h4>
                <hr class="bg-light">
            </div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Admin")" class="nav-link text-light">
                        <i class="bi bi-speedometer"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item mb-3">
                    <a href="@Url.Action("Index", "Movies")" class="nav-link text-light">
                        <i class="bi bi-film"></i> Movie Management
                    </a>
                </li>
                <li class="nav-item mb-3">
                    <a href="@Url.Action("Index", "Categories")" class="nav-link text-light">
                        <i class="bi bi-tags"></i> Category Management
                    </a>
                </li>
                <li class="nav-item mb-3">
                    <a href="@Url.Action("Index", "Users")" class="nav-link text-light">
                        <i class="bi bi-people"></i> User Management
                    </a>
                </li>
            </ul>
            <div class="logout-section">
                @if (Request.IsAuthenticated)
                {
                    using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm" }))
                    {
                        @Html.AntiForgeryToken()
                        <a class="nav-link" href="javascript:document.getElementById('logoutForm').submit()">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </a>}
                }
            </div>
        </nav>

        <!-- Main Content -->
        <div class="content p-4" style="flex-grow: 1;">
            @RenderBody()
            @*<h2>Welcome to the Admin Panel</h2>
            <p>Use the side menu to navigate through management options.</p>*@
        </div>
    </div>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.js"></script>
    }
</body>
</html>
