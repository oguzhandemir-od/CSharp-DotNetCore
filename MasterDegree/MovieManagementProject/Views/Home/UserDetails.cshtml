
@{
    ViewBag.Title = "UserDetails";
}

<h2>@Model.Title</h2>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Movies</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/Content/custom.css">
</head>

<div class="movie-details-section">
    <div class="container">
        <div class="row">
            <div class="col-md-6">
                <!-- Film Posteri -->
                <div class="movie-poster">
                    <img src="" alt="@Model.Title" class="img-fluid">
                </div>
            </div>

            <div class="col-md-6">
                <!-- Film Detayları -->
                <div class="movie-info">
                    <h2>@Model.Title</h2>
                    <p class="director"><strong>Yönetmen:</strong> @Model.Director</p>
                    <p class="release-year"><strong>Yıl:</strong> @Model.Year</p>
                    <p class="category"><strong>Kategori:</strong> @Model.Category.Name</p>
                    @*<p class="description">@Model.Description</p>*@

                    <!-- İzleme Butonu -->
                    @*<a href="@Model.VideoUrl" class="btn btn-light btn-lg" target="_blank">Filmi İzle</a>*@
                </div>
            </div>
        </div>
    </div>
</div>
