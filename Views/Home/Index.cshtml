    <div class="hero-section">
        <div class="container text-center text-light">
            <h1>Welcome to Movie World!</h1>
            <p>Discover the latest and most popular movies, create your watchlist.</p>
            <a href="@Url.Action("UserIndex", "Home")" class="btn btn-light btn-lg">Find Movies</a>
        </div>
    </div>
    <main>
