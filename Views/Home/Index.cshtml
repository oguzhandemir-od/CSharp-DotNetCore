        <!-- Popüler Filmler -->
        <div class="popular-movies-section">
            <div class="container">
                <h2 class="section-title text-center text-light">Popular Movies</h2>
                <div class="row">
                    <!-- Film kartları burada dinamik olarak yerleştirilecek -->
                    <div class="col-md-4 movie-card">
                        <img src="path_to_image" alt="Film 1" class="img-fluid">
                        <h5>Movie 1</h5>
                        <p>Director: X</p>
                        <a href="/Movies/Details/1" class="btn btn-light">Details</a>
                    </div>
                    <div class="col-md-4 movie-card">
