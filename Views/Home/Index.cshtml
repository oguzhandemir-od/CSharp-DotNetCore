        <!-- Film Kategorileri -->
        <div class="categories-section">
            <div class="container">
                <h2 class="section-title text-center text-light">Categories</h2>
                <div class="row">

                    @foreach (var category in categories)
                    {
                        <div class="col-md-4 category-card">
                            <h4>@category.Name</h4>
                            <a href="@Url.Action("ViewByCategory", "Home", new { id = category.Id })" class="btn btn-light">
                                See
                            </a>
                        </div>
                            }
                        
