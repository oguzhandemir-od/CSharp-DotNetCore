@using MvcOnlineTicariOtomasyon.Models.Siniflar
@model IEnumerable<SatisHareket>
@{
    ViewData["Title"] = "CariSatisGecmis";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h1>Cari Satış Geçmişi</h1>
<br />
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item active">
        Cari: @ViewBag.CariAdi
    </li>
</ol>
<table class="table table-hover">
    <tr>
        <th>Satış ID</th>
        <th>Ürün</th>
        <th>Satan Personel</th>
        <th>Fiyat</th>
        <th>Adet</th>
        <th>Toplam</th>
        <th>Tarih</th>
        <th>Yazdır</th>
    </tr>
    @foreach (var s in Model)
    {
        <tr>
            <td>@s.Satishareketid</td>
            <td>@s.Urun.UrunAd</td>
            <td>@s.Personel.PersonelAd @s.Personel.PersonelSoyad</td>
            <td>@s.Fiyat</td>
            <td>@s.Adet</td>
            <td>@s.ToplamTutar</td>
            <td>@s.Tarih</td>
            <td><a href="" class="btn btn-primary">Yazdır</a></td>
        </tr>
    }
</table>

