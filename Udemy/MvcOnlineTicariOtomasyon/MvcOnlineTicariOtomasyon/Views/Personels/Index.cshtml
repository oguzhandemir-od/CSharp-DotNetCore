@using MvcOnlineTicariOtomasyon.Models.Siniflar
@model IEnumerable<Personel>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<table class="table table-bordered mt-2">
    <tr>
        <th>ID</th>
        <th>Personel Adı</th>
        <th>Personel Soyadı</th>
        <th>Görsel</th>
        <th>Departman</th>
        <th>Güncelle</th>
        <th>Satışlar</th>
    </tr>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Personelid</td>
            <td>@p.PersonelAd</td>
            <td>@p.PersonelSoyad</td>
            <td><img src="@p.PersonelGorsel" style="height:100px; width:auto;" /></td>
            <td>@p.Departman.DepartmanAd</td>
            <td><a href="/Personels/PersonelGetir/@p.Personelid" class="btn btn-success">Güncelle</a></td>
            <td><a href="/Departmans/DepartmanPersonelSatis/@p.Personelid" class="btn btn-info">Satışlar</a></td>
        </tr>
    }
</table>
<a href="/Personels/PersonelEkle" class="btn btn-primary">Personel Ekle</a>
<a href="/Personels/PersonelListe" class="btn btn-primary">Personel Listesi</a>

