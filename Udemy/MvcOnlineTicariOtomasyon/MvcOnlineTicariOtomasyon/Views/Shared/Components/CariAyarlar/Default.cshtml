@using MvcOnlineTicariOtomasyon.Models.Siniflar
@model MvcOnlineTicariOtomasyon.Models.Siniflar.Cariler
@{
	ViewData["Title"] = "Index";	
}

<form class="form-horizontal" method="post">

    <div class="form-group row">

        <label for="inputName" class="col-sm-2 col-form-label">Ad</label>

        <div class="col-sm-10">

            <input asp-for="CariAd" type="text" class="form-control" id="inputName" value="@Model.CariAd">

        </div>

    </div>

    <div class="form-group row">

        <label for="inputName" class="col-sm-2 col-form-label">Soyad</label>

        <div class="col-sm-10">

            <input asp-for="CariSoyad" type="text" class="form-control" id="inputName2" value="@Model.CariSoyad">

        </div>

    </div>

    <div class="form-group row">

        <label for="inputEmail" class="col-sm-2 col-form-label">Email</label>

        <div class="col-sm-10">

            <input asp-for="CariMail" type="email" class="form-control" id="inputEmail" value="@Model.CariMail">

        </div>

    </div>

    <div class="form-group row">

        <label for="inputName2" class="col-sm-2 col-form-label">Şehir</label>

        <div class="col-sm-10">

            <input asp-for="CariSehir" type="text" class="form-control" id="inputName2" value="@Model.CariSehir">

        </div>

    </div>

    <div class="form-group row">

        <label for="inputExperience" class="col-sm-2 col-form-label">Şifre</label>

        <div class="col-sm-10">

            <input asp-for="CariSifre" class="form-control" id="inputExperience" value="@Model.CariSifre">

        </div>

    </div>
    

    <div class="form-group row">

        <div class="offset-sm-2 col-sm-10">

            <div class="checkbox">

                <label>

                    <input type="checkbox"> Bilgilerimi değiştirmeyi kabul ediyorum

                </label>

            </div>

        </div>

    </div>

    <div class="form-group row">

        <div class="offset-sm-2 col-sm-10">

            <button asp-controller="CariPanel" asp-action="CariBilgiGuncelle" type="submit" class="btn btn-danger">Tamam</button>

        </div>

    </div>

</form>

@{
}
