@model MvcOnlineTicariOtomasyon.Models.Siniflar.Cariler

<div class="login-form login-form-left">
	<div class="agile-row">
		<h3>Yeni Cari Kaydı</h3>
		<div class="login-agileits-top">
			<form asp-controller="Login" asp-action="ClientRegister" method="post">
				<input type="text" class="name" name="CariAd" Placeholder="Adınız" required="" />
				<input type="text" class="name" name="CariSoyad" Placeholder="Soyadınız" required="" />
				<input type="text" class="name" name="CariSehir" Placeholder="Şehir" required="" />
				<input type="email" class="email" name="CariMail" Placeholder="Eposta Adresiniz" required="" />
				<input type="password" class="password" name="CariSifre" Placeholder="Şifre" required="" />
				<div class="login-check">
					<label class="checkbox"><input type="checkbox" name="checkbox" checked=""><i> </i>  <a href="#">Kuralları ve şartları</a> okudum ve kabul ediyorum</label>
				</div>
				<input type="submit" value="Kaydol">
			</form>
		</div>
	</div>
</div>
