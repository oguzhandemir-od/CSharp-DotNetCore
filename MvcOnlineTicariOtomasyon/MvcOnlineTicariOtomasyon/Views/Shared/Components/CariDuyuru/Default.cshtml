@using MvcOnlineTicariOtomasyon.Models.Siniflar
@model IEnumerable<Mesajlar>
@{
}

<div class="timeline timeline-inverse">

    
    @foreach(var m in Model)
    {
        <!-- timeline time label -->
        <div class="time-label">

            <span class="bg-danger">

                @m.Tarih.ToString("dd.MM.yyyy")

            </span>

        </div>

        <!-- /.timeline-label -->
        <!-- timeline item -->

        <div>

            <i class="fas fa-envelope bg-primary"></i>

            <div class="timeline-item">

                <span class="time"><i class="far fa-clock"></i> @m.Tarih.ToString("HH:mm")</span>

                <h3 class="timeline-header"><a href="#">Admin</a> bir duyuru paylaştı - @m.Konu</h3>

                <div class="timeline-body">

                    @m.Icerik

                </div>

                <div class="timeline-footer">

                    <a href="#" class="btn btn-primary btn-sm">Devamını oku</a>

                    <a href="#" class="btn btn-danger btn-sm">Sil</a>

                </div>

            </div>

        </div>

        <!-- END timeline item -->
        <!-- timeline item -->
    }
    <div>

        <i class="far fa-clock bg-gray"></i>

    </div>

</div>