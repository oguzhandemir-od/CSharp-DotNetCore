@model IEnumerable<MvcOnlineTicariOtomasyon.Models.DTO.UrunMarkaDto>

<div class="card">
	<div class="card-header">
		<h3 class="card-title">Marka Dağılımı</h3>
	</div>
	<!-- /.card-header -->
	<div class="card-body p-0">
		<table class="table table-striped">
			<thead>
				<tr>
					<th style="width: 10px">#</th>
					<th>Marka</th>
					<th>Gösterge</th>
					<th style="width: 40px">Toplam</th>
				</tr>
			</thead>

			<tbody>
				@{
					int sirano = 0;
				}
				@foreach (var m in Model)
				{
					<tr>
						<td>
							@{
								sirano++;
							} @sirano
						</td>
						<td>@m.Marka</td>
						<td>
							<div class="progress progress-xs">
								<div class="progress-bar progress-bar-danger" style="width: @(m.Sayi * 100 / ViewBag.ToplamUrun)%"></div>
							</div>
						</td>
						<td><span class="badge bg-danger">@m.Sayi</span></td>
					</tr>
				}
			</tbody>
		</table>
	</div>
	<!-- /.card-body -->
</div>
